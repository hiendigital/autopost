# ==== AutoContentPipeline environment variables ====
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Set DRY_RUN=1 to mock ALL external APIs (no keys needed, nothing published, no credits spent).
# Set DRY_RUN=0 (or remove) to hit real services.
DRY_RUN=1

# --- OpenAI (content + prompt translation) ---
OPENAI_API_KEY=

# --- Replicate (Flux 1.1 Pro image generation) ---
REPLICATE_API_TOKEN=

# --- WordPress REST API ---
# Base site URL, e.g. https://example.com  (no trailing slash)
WP_BASE_URL=
WP_USER=
# WordPress Application Password (Users -> Profile -> Application Passwords)
WP_APP_PASSWORD=

# --- Facebook Graph API ---
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
